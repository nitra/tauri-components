{
  "private": true,
  "workspaces": [
    "npm"
  ],
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "coverage": "7n-test coverage",
    "lint": "bun run lint-js && bun run lint-text && bun run lint-ga && bun run lint-rust && bun run lint-security && oxfmt .",
    "lint-js": "bunx oxlint --fix && bunx eslint --fix . && bunx jscpd . && bunx knip --no-config-hints",
    "lint-text": "n-cursor lint-text",
    "lint-ga": "n-cursor lint-ga",
    "lint-rust": "cd tauri-plugin-agent && cargo fmt --all && cargo clippy --fix --allow-staged --allow-dirty --all-targets --all-features && cargo clippy --all-targets --all-features -- -D warnings",
    "lint-security": "trufflehog filesystem . --no-update --exclude-paths .trufflehog-exclude --results=verified,unknown --fail"
  },
  "devDependencies": {
    "@7n/rules": "^1.37.0",
    "@7n/rules-ci-github": "^1.9.0",
    "@7n/rules-lang-js": "^0.12.0",
    "@7n/rules-lang-rust": "^0.6.1",
    "@7n/test": "^0.17.0",
    "@nitra/cspell-dict": "^2.2.2",
    "@nitra/eslint-config": "^3.10.0",
    "@quasar/extras": "^2.0.2",
    "@quasar/vite-plugin": "^1.12.0",
    "@storybook/addon-vitest": "^10.5.3",
    "@storybook/builder-vite": "^10.5.3",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vitest/browser": "^4.1.10",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "playwright": "^1.61.1",
    "quasar": "^2.21.4",
    "vitest": "^4.1.10",
    "vue": "^3.5.40"
  },
  "stylelint": {
    "extends": "@nitra/stylelint-config"
  }
}
