{
  "name": "@7n/tauri-components",
  "version": "0.14.0",
  "type": "module",
  "description": "Shared LLM agent engine + Vue/Quasar UI for Tauri apps (chat, journal, trust-tier approval).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nitra/tauri-components.git",
    "directory": "npm"
  },
  "publishConfig": {
    "access": "public"
  },
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./src/index.js"
    },
    "./vue": {
      "types": "./types/vue/index.d.ts",
      "default": "./src/vue/index.js"
    },
    "./components": {
      "types": "./types/components/index.d.ts",
      "default": "./src/components/index.js"
    },
    "./testing": {
      "types": "./types/testing/index.d.ts",
      "default": "./src/testing/index.js"
    }
  },
  "files": [
    "src",
    "types",
    "CHANGELOG.md",
    "!**/*.test.*",
    "!**/*.spec.*",
    "!**/*.stories.*",
    "!**/__tests__/**",
    "!**/fixtures/**"
  ],
  "dependencies": {
    "marked": "^18.0.7"
  },
  "peerDependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-http": "^2.0.0",
    "@tauri-apps/plugin-process": "^2.0.0",
    "@tauri-apps/plugin-updater": "^2.0.0",
    "@vue/test-utils": "^2.0.0",
    "quasar": "^2.0.0",
    "vue": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@tauri-apps/api": {
      "optional": true
    },
    "@tauri-apps/plugin-http": {
      "optional": true
    },
    "quasar": {
      "optional": true
    }
  },
  "knip": {
    "ignoreDependencies": [
      "marked"
    ]
  },
  "engines": {
    "bun": ">=1.3",
    "node": ">=24"
  },
  "devDependencies": {
    "@quasar/extras": "^2.0.2",
    "@storybook/addon-vitest": "^10.5.3",
    "@storybook/vue3-vite": "^10.5.3",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vitest/browser": "^4.1.10",
    "@vitest/browser-playwright": "^4.1.10",
    "playwright": "^1.61.1",
    "storybook": "^10.5.3"
  }
}
