{
  "name": "@7n/tauri-components",
  "version": "0.13.10",
  "type": "module",
  "description": "Shared LLM agent engine + Vue/Quasar UI for Tauri apps (chat, journal, trust-tier approval).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nitra/tauri-components.git",
    "directory": "npm"
  },
  "publishConfig": {
    "access": "public"
  },
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./src/index.js"
    },
    "./vue": "./src/vue/index.js",
    "./components": "./src/components/index.js",
    "./testing": "./src/testing/index.js"
  },
  "files": [
    "src",
    "types",
    "CHANGELOG.md",
    "!**/*.test.*",
    "!**/*.spec.*",
    "!**/*.stories.*",
    "!**/__tests__/**",
    "!**/fixtures/**"
  ],
  "dependencies": {
    "marked": "^18.0.7"
  },
  "peerDependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-http": "^2.0.0",
    "@tauri-apps/plugin-process": "^2.0.0",
    "@tauri-apps/plugin-updater": "^2.0.0",
    "@vue/test-utils": "^2.0.0",
    "quasar": "^2.0.0",
    "vue": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "@tauri-apps/api": {
      "optional": true
    },
    "@tauri-apps/plugin-http": {
      "optional": true
    },
    "quasar": {
      "optional": true
    }
  },
  "knip": {
    "ignoreDependencies": [
      "marked"
    ]
  },
  "engines": {
    "bun": ">=1.3",
    "node": ">=24"
  },
  "scripts": {
    "storybook": "storybook dev -p 6006 --no-open"
  },
  "devDependencies": {
    "@storybook/vue3-vite": "^10.5.3",
    "msw": "2.11.3",
    "msw-storybook-addon": "2.0.5",
    "storybook": "^10.5.3"
  },
  "msw": {
    "workerDirectory": [
      ".storybook/public"
    ]
  }
}
